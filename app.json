{
  "expo": {
    "name": "unwindRN",
    "slug": "unwindrn",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "unwindrn",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#090F0E",
    "ios": {
      "bundleIdentifier": "com.unwindrn.app",
      "buildNumber": "1",
      "supportsTablet": false,
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSSpeechRecognitionUsageDescription": "Your words are transcribed on this phone — only the text you approve is saved.",
        "NSMicrophoneUsageDescription": "unwindRN listens only while you debrief. Audio never leaves your phone."
      }
    },
    "plugins": [
      "expo-router",
      "expo-apple-authentication",
      "expo-secure-store",
      "expo-audio",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "unwindRN listens only while you debrief. Audio never leaves your phone.",
          "speechRecognitionPermission": "Your words are transcribed on this phone — only the text you approve is saved."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#090F0E",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 96
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "72ba8228-8d80-4e84-80a8-4141cce4754e"
      }
    },
    "owner": "unwindrn"
  }
}
