{
  "expo": {
    "name": "unwindRN",
    "slug": "unwindrn",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "unwindrn",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#14152B",
    "ios": {
      "bundleIdentifier": "com.unwindrn.app",
      "buildNumber": "1",
      "supportsTablet": false,
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "plugins": [
      "expo-router",
      "expo-apple-authentication",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#14152B",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 120
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
